# --- APP CONFIG ---
BASE_URL=http://localhost:8000

# --- SUPABASE AUTH & DATABASE ---
# Get these from Supabase Settings -> API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_JWT_SECRET=your-jwt-secret-for-backend-verification

# --- AI PROVIDERS ---
# Get from https://console.groq.com/
GROQ_API_KEY=gsk_your_key_here

# --- PAYMENTS (STRIPE) ---
# Optional: Only needed for monetization
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# --- CLOUD STORAGE (OPTIONAL) ---
# Use "cloud" for S3/R2 storage, "local" for disk storage
STORAGE_MODE=local
S3_ENDPOINT_URL=https://your-id.r2.cloudflarestorage.com
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET_NAME=opus-pro-assets
S3_REGION=auto

# --- INFRASTRUCTURE ---
REDIS_URL=redis://redis:6379/0
